
# ID Spreadsheet Google Sheets (bisa dilihat di URL spreadsheet)
GOOGLE_SPREADSHEET_ID=isi_id_spreadsheet_kamu_di_sini

# Path ke file JSON Service Account (HANYA untuk dev lokal)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Untuk Railway/Cloud: paste SELURUH ISI file service_account.json di sini (dalam satu baris)
# Kalau variabel ini diisi, GOOGLE_SERVICE_ACCOUNT_FILE diabaikan
GOOGLE_SERVICE_ACCOUNT_JSON=

# API Key dari OpenRouter
OPENROUTER_API_KEY=isi_api_key_openrouter_kamu_di_sini
